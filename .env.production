# SD.cpp Studio Production Environment Variables
# This file is used by the systemd service
#
# To apply changes:
#   1. Edit this file
#   2. Run: systemctl --user restart sd-cpp-studio
#

# Host configuration
ALLOWED_HOSTS=studio.rscx.ru
BACKEND_HOST=192.168.1.48
HOST=192.168.1.48

# Node environment
NODE_ENV=production
